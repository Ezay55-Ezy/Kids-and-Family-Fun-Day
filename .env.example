# -----------------------------------------------------------------
# Kids & Family Fun Day Kenya — Environment Variables
# Copy this file to .env and fill in the values.
# -----------------------------------------------------------------

# Database Connections (Neon Postgres)
# DATABASE_URL: Set the Neon dashboard toggle to "Pooled"
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
# DIRECT_URL: Set the Neon dashboard toggle to "Direct"
DIRECT_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Framework Authentication (Auth.js / Next-Auth)
# Generate a secure key by running: npx auth secret
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="http://localhost:3000"

# QR Ticket Check-in Base URL
# Must be the public URL of the app in production
NEXT_PUBLIC_CHECKIN_BASE_URL="http://localhost:3000"

# Media Storage (Cloudinary API Credentials)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Mobile Money Integrations (Safaricom M-Pesa Daraja API)
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_SHORTCODE=""
MPESA_PASSKEY=""
MPESA_ENVIRONMENT="sandbox"

# Browser Push Notifications (VAPID Keys for Web Push)
# Generate by running: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@kidsfamilyfunday.co.ke"

# Transactional Email System (Resend API)
RESEND_API_KEY=""
# Sender address — must use a domain verified in Resend dashboard
EMAIL_FROM="Kids & Family Fun Day Kenya <noreply@kidsfamilyfunday.co.ke>"

# Rate Limiting (Upstash Redis — free tier at upstash.com or via Vercel Marketplace)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
